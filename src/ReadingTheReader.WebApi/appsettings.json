{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "RealtimePersistence": {
    "Provider": "InMemory",
    "SnapshotFilePath": "./data/experiment-session-snapshot.json",
    "CheckpointIntervalMilliseconds": 2000
  },
  "ReadingMaterialSetupStorage": {
    "DirectoryPath": "./data/reading-material-setups"
  },
  "Calibration": {
    "PresetPointCount": 16
  }
}
